{
    "manifest_version": 3,
    "name": "Asterisk",
    "version": "0.1.0",
    "description": "Warns you before sensitive details slip into AI conversations.",
    "minimum_chrome_version": "149",
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "action": {
        "default_popup": "src/popup/popup.html",
        "default_title": "Asterisk",
        "default_icon": {
            "16": "icons/icon-16.png",
            "48": "icons/icon-48.png",
            "128": "icons/icon-128.png"
        }
    },
    "permissions": ["storage"],
    "host_permissions": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://grok.com/*",
        "https://chat.mistral.ai/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*"
    ],
    "background": {
        "service_worker": "src/background/service-worker.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://chatgpt.com/*",
                "https://chat.openai.com/*",
                "https://claude.ai/*",
                "https://gemini.google.com/*",
                "https://copilot.microsoft.com/*",
                "https://grok.com/*",
                "https://chat.mistral.ai/*",
                "https://www.perplexity.ai/*",
                "https://perplexity.ai/*"
            ],
            "js": [
                "src/config/sites.js",
                "src/lib/storage.js",
                "src/content/pii-detector.js",
                "src/lib/icons.js",
                "src/content/warning-ui.js",
                "src/content/content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "options_page": "src/settings/settings.html"
}
